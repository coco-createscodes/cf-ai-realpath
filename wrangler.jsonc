{
  "name": "cf-ai-realpath",
  "main": "src/index.js",
  "compatibility_date": "2025-03-05",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "REALPATH_SESSION",
        "class_name": "RealpathSession"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RealpathSession"]
    }
  ]
}